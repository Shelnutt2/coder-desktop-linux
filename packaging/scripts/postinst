#!/bin/sh
# Post-install scriptlet shared by the .deb and .rpm packages.
# Reloads systemd and the D-Bus system bus so the freshly installed
# coder-desktop-helper service and bus policy take effect immediately.
# All actions are best-effort: they are skipped in containers/chroots
# where systemd or dbus is not running.
set -e

if command -v systemctl >/dev/null 2>&1; then
    systemctl daemon-reload >/dev/null 2>&1 || true
fi

if command -v dbus-send >/dev/null 2>&1; then
    dbus-send --system --type=method_call \
        --dest=org.freedesktop.DBus \
        /org/freedesktop/DBus \
        org.freedesktop.DBus.ReloadConfig >/dev/null 2>&1 || true
fi

exit 0
