#!/usr/bin/env bash
# Pre-commit hook: run clang-format on staged C/C++ files
set -euo pipefail

CHANGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(c|h|cpp)$' || true)
if [ -z "$CHANGED_FILES" ]; then
    exit 0
fi

if ! command -v clang-format &>/dev/null; then
    echo "Warning: clang-format not found, skipping format check"
    exit 0
fi

UNFORMATTED=$(echo "$CHANGED_FILES" | xargs clang-format --dry-run --Werror 2>&1 || true)
if [ -n "$UNFORMATTED" ]; then
    echo "❌ clang-format check failed. Run:"
    echo "  find app/src coder-dlp-compositor/src -type f \\( -name '*.h' -o -name '*.cpp' -o -name '*.c' \\) -exec clang-format -i {} +"
    echo ""
    echo "$UNFORMATTED"
    exit 1
fi
